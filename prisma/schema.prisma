// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum ConsentType {
  TERMS_OF_SERVICE
  PRIVACY_POLICY

  @@map("consent_type")
}

enum ScheduleStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELED

  @@map("schedule_status")
}

enum Season {
  SPRING
  SUMMER
  FALL
  WINTER

  @@map("season")
}

enum Gender {
  MALE
  FEMALE

  @@map("gender")
}

enum RoomInspectionType {
  FULL
  SOLO
  EMPTY

  @@map("room_inspection_type")
}

enum Role {
  ADMIN
  USER

  @@map("role")
}

enum ArticleType {
  NOTICE
  FAQ

  @@map("article_type")
}

enum ApplicationStatus {
  PASSED
  FAILED
  PENDING_NO_SHOW
  NO_SHOW
  CANCELED
  NO_SHOW_CANCELED

  @@map("application_status")
}

model User {
  uuid          String @id @db.Uuid
  studentHash   String @unique @map("student_hash")
  name          String
  email         String
  phoneNumber   String @map("phone_number")
  studentNumber String @map("student_number")
  role          Role   @default(USER)

  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  userRefreshTokens      UserRefreshToken[]
  userConsents           UserConsent[]
  inspectionApplications InspectionApplication[]
  auditLogs              AuditLog[]

  @@map("user")
}

model UserRefreshToken {
  uuid         String   @id @default(uuid()) @db.Uuid
  userUuid     String   @map("user_uuid") @db.Uuid
  refreshToken String   @unique @map("refresh_token")
  sessionId    String   @map("session_id")
  createdAt    DateTime @default(now()) @map("created_at")
  expiredAt    DateTime @map("expired_at")

  user User @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)

  @@index([userUuid, sessionId])
  @@map("user_refresh_token")
}

model UserConsent {
  uuid        String      @id @default(uuid()) @db.Uuid
  userUuid    String      @map("user_uuid") @db.Uuid
  consentType ConsentType @map("consent_type")
  version     String
  agreedAt    DateTime    @default(now()) @map("agreed_at")

  user User @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)

  @@index([userUuid, consentType])
  @@map("user_consent")
}

model AuditLog {
  uuid        String   @id @default(uuid()) @db.Uuid
  action      String
  data        String
  userUuid    String   @map("user_uuid") @db.Uuid
  performedAt DateTime @default(now()) @map("performed_at")

  user User @relation(fields: [userUuid], references: [uuid])

  @@index([performedAt])
  @@map("audit_log")
}

model MoveOutSchedule {
  uuid                 String         @id @default(uuid()) @db.Uuid
  title                String
  applicationStartTime DateTime       @map("application_start_time")
  applicationEndTime   DateTime       @map("application_end_time")
  currentSemesterUuid  String         @map("current_semester_uuid") @db.Uuid
  nextSemesterUuid     String         @map("next_semester_uuid") @db.Uuid
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @default(now()) @updatedAt @map("updated_at")
  status               ScheduleStatus @default(DRAFT)

  inspectionSlots   InspectionSlot[]
  inspectionTargets InspectionTargetInfo[]
  inspectors        MoveOutScheduleOnInspector[]

  currentSemester Semester @relation("ScheduleCurrentSemester", fields: [currentSemesterUuid], references: [uuid], onDelete: Cascade)
  nextSemester    Semester @relation("ScheduleNextSemester", fields: [nextSemesterUuid], references: [uuid], onDelete: Cascade)

  @@map("move_out_schedule")
}

model MoveOutScheduleOnInspector {
  scheduleUuid  String  @map("schedule_uuid") @db.Uuid
  inspectorUuid String  @map("inspector_uuid") @db.Uuid
  isTemporary   Boolean @default(false) @map("is_temporary")

  schedule  MoveOutSchedule @relation(fields: [scheduleUuid], references: [uuid], onDelete: Cascade)
  inspector Inspector       @relation(fields: [inspectorUuid], references: [uuid], onDelete: Cascade)

  @@id([scheduleUuid, inspectorUuid])
  @@map("move_out_schedule_on_inspector")
}

model Semester {
  uuid      String   @id @default(uuid()) @db.Uuid
  year      Int
  season    Season
  createdAt DateTime @default(now()) @map("created_at")

  currentSemesterSchedules MoveOutSchedule[] @relation("ScheduleCurrentSemester")
  nextSemesterSchedules    MoveOutSchedule[] @relation("ScheduleNextSemester")

  @@unique([year, season])
  @@map("semester")
}

model InspectionTargetInfo {
  uuid                  String             @id @default(uuid()) @db.Uuid
  scheduleUuid          String             @map("schedule_uuid") @db.Uuid
  houseName             String             @map("house_name")
  gender                Gender             @map("gender")
  roomNumber            String             @map("room_number")
  roomCapacity          Int                @map("room_capacity")
  student1Name          String?            @map("student1_name")
  student1StudentNumber String?            @map("student1_student_number")
  student2Name          String?            @map("student2_name")
  student2StudentNumber String?            @map("student2_student_number")
  student3Name          String?            @map("student3_name")
  student3StudentNumber String?            @map("student3_student_number")
  studentHashes         String[]           @map("student_hashes")
  applyCleaningService  Boolean            @default(false) @map("apply_cleaning_service")
  applyRepairCheck      Boolean            @default(false) @map("apply_repair_check")
  inspectionType        RoomInspectionType @map("inspection_type")
  inspectionCount       Int                @default(0) @map("inspection_count")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @default(now()) @updatedAt @map("updated_at")

  schedule              MoveOutSchedule         @relation(fields: [scheduleUuid], references: [uuid], onDelete: Cascade)
  inspectionApplication InspectionApplication[]

  @@unique([scheduleUuid, houseName, roomNumber], name: "inspection_target_room_unique")
  @@index([scheduleUuid])
  @@map("inspection_target")
}

model InspectionSlot {
  uuid          String   @id @default(uuid()) @db.Uuid
  scheduleUuid  String   @map("schedule_uuid") @db.Uuid
  startTime     DateTime @map("start_time")
  endTime       DateTime @map("end_time")
  gender        Gender   @map("gender")
  capacity      Int      @default(0) @map("capacity")
  reservedCount Int      @default(0) @map("reserved_count")

  inspectionApplications InspectionApplication[]
  inspectors             InspectorAvailableSlot[]
  schedule               MoveOutSchedule          @relation(fields: [scheduleUuid], references: [uuid], onDelete: Cascade)

  @@unique([scheduleUuid, startTime, endTime, gender])
  @@map("inspection_slot")
}

model InspectionApplication {
  uuid                     String             @id @default(uuid()) @db.Uuid
  userUuid                 String             @map("user_uuid") @db.Uuid
  inspectionTargetInfoUuid String             @map("inspection_target_info_uuid") @db.Uuid
  inspectionSlotUuid       String             @map("inspection_slot_uuid") @db.Uuid
  status                   ApplicationStatus?
  itemResults              Json?              @map("item_results")
  additionalComment        String?            @map("additional_comment")
  document                 String?
  isDocumentActive         Boolean?           @map("is_document_active")
  createdAt                DateTime           @default(now()) @map("created_at")
  updatedAt                DateTime           @default(now()) @updatedAt @map("updated_at")
  deletedAt                DateTime?          @map("deleted_at")
  inspectorUuid            String             @map("inspector_uuid") @db.Uuid
  inspectionCount          Int                @map("inspection_count")

  user                 User                 @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)
  inspectionTargetInfo InspectionTargetInfo @relation(fields: [inspectionTargetInfoUuid], references: [uuid], onDelete: Cascade)
  inspectionSlot       InspectionSlot       @relation(fields: [inspectionSlotUuid], references: [uuid], onDelete: Cascade)
  inspector            Inspector            @relation(fields: [inspectorUuid], references: [uuid])

  // status가 null 또는 PENDING_NO_SHOW이고 deletedAt이 null인 row에 대해
  // inspectionTargetInfoUuid 유니크 인덱스를 두어 한 target당 활성 Application 1개만 허용
  // add_unique_active_application_status 데이터베이스 마이그레이션 파일 참고
  @@index([inspectionSlotUuid])
  @@map("inspection_application")
}

model InspectorAvailableSlot {
  inspectorUuid      String @map("inspector_uuid") @db.Uuid
  inspectionSlotUuid String @map("inspection_slot_uuid") @db.Uuid

  inspector      Inspector      @relation(fields: [inspectorUuid], references: [uuid], onDelete: Cascade)
  inspectionSlot InspectionSlot @relation(fields: [inspectionSlotUuid], references: [uuid], onDelete: Cascade)

  @@id([inspectorUuid, inspectionSlotUuid])
  @@map("inspector_available_slot")
}

model Inspector {
  uuid          String @id @default(uuid()) @db.Uuid
  studentHash   String @unique @map("student_hash")
  name          String
  email         String
  studentNumber String @map("student_number")
  gender        Gender

  availableSlots InspectorAvailableSlot[]
  applications   InspectionApplication[]
  schedules      MoveOutScheduleOnInspector[]

  @@map("inspector")
}

model Article {
  uuid      String      @id @default(uuid()) @db.Uuid
  type      ArticleType
  titleKo   String      @map("title_ko")
  titleEn   String      @map("title_en")
  contentKo String      @map("content_ko")
  contentEn String      @map("content_en")
  isVisible Boolean     @default(true) @map("is_visible")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @default(now()) @updatedAt() @map("updated_at")
  deletedAt DateTime?   @map("deleted_at")

  @@map("article")
}
